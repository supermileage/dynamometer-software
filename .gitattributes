# Normalize line endings to LF in the repository.
* text=auto eol=lf

*.cs    text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.slnx  text eol=lf
*.axaml text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.ps1   text eol=lf

# Binary assets
*.png binary
*.ico binary
