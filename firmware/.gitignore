#settings
.settings/

#metadata
.metadata/

#Debug
Debug/
debug/
Release/
release/

# CMake build output (build/ = native/IDE, build-docker/ = Scripts/build-docker.sh)
build/
build-docker/
tests/build/

# Compile-time overrides written by the desktop app before a build (config.h / debug.h are the
# committed defaults; these hold only what the user changed, so they are per-machine, not shared).
Core/Inc/Config/config_overrides.h
Core/Inc/Config/debug_overrides.h

# build log
build_log.txt

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
*.bin

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Freemarker template files
*.ftl

# STM32CubeIDE temporary files
MXTmpFiles/

# vscode files
.vscode/
# The open-source flashing tools under Scripts/tools/ ARE committed (see its README) so a clone can
# flash with nothing installed. The blanket *.so / *.dll / *.exe rules above would hide them, so
# re-include everything under Scripts/tools/ ...
!Scripts/tools/**
# ... except STM32CubeProgrammer, which is proprietary and must never be committed, whatever
# platform dir someone drops it in. (Listed last so it wins over the re-include above.)
Scripts/tools/**/STM32_Programmer_CLI*
Scripts/tools/**/*cubeprog*
