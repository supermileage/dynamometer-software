<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:Dyno.App.ViewModels"
  xmlns:controls="using:Dyno.App.Controls"
  x:Class="Dyno.App.Views.PlotsView"
  x:DataType="vm:MainWindowViewModel"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <!-- The drag grip along a graph's bottom edge (same affordance as the event log's): full
         width, because a resize handle you have to hunt for is one nobody finds. -->
    <Style Selector="Thumb.resize">
      <Setter Property="Height" Value="10" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Cursor" Value="SizeNorthSouth" />
      <Setter Property="Margin" Value="0,2,0,-6" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="Transparent" HorizontalAlignment="Stretch">
            <Border
              Width="34"
              Height="3"
              CornerRadius="2"
              Background="{StaticResource StrokeBrush}"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
            />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Thumb.resize:pointerover /template/ Border > Border">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    </Style>
    <!-- Channel chips: toggle a channel onto/off a graph. The checked set doubles as the
         graph's legend (swatch + name), so no line is ever identified by color alone. -->
    <Style Selector="ToggleButton.chip">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Padding" Value="7,3" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.chip:checked /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="14">
    <Border Grid.Row="0" Classes="card" Padding="12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
          <TextBlock Classes="heading" Text="PLOTS" />
          <TextBlock
            Classes="label"
            FontSize="12"
            Text="Toggle any set of channels onto a graph — each line is drawn against its own range (Settings > Plots, or autoscale), and the y-axis numbers belong to the channel picked on the graph. Drag the grip under a graph to resize it; add as many as you need."
            TextWrapping="Wrap"
          />
        </StackPanel>
        <Button
          Grid.Column="1"
          Classes="accent"
          Content="Add graph"
          Command="{Binding Plots.AddGraphCommand}"
          VerticalAlignment="Center"
        />
      </Grid>
    </Border>

    <!-- One card per graph, each overlaying any set of channels over a shared time window.
         Units differ per channel, so there is no shared or dual y-scale: every series is
         normalized to its own configured range and the axis labels follow the picked channel. -->
    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="10">
        <ItemsControl ItemsSource="{Binding Plots.Graphs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="10" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:PlotGraphViewModel">
              <Border Classes="card" Padding="12,8,12,10">
                <StackPanel Spacing="6">
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <ItemsControl Grid.Column="0" ItemsSource="{Binding Series}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <WrapPanel ItemSpacing="5" LineSpacing="5" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlotGraphSeriesViewModel">
                          <ToggleButton
                            Classes="chip"
                            IsChecked="{Binding IsShown}"
                            ToolTip.Tip="{Binding Channel.Title}"
                          >
                            <StackPanel Orientation="Horizontal" Spacing="5">
                              <Border
                                Width="9"
                                Height="9"
                                CornerRadius="3"
                                Background="{Binding Channel.Stroke}"
                                VerticalAlignment="Center"
                              />
                              <TextBlock Text="{Binding Channel.Name}" VerticalAlignment="Center" />
                            </StackPanel>
                          </ToggleButton>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Every series is drawn against its own range (Settings > Plots, or its
                         autoscale fit); the numbers on the left belong to this channel only. -->
                    <StackPanel
                      Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center"
                      ToolTip.Tip="Which channel's scale labels the y-axis. Every line is normalized to its own configured range, so shapes compare even when units differ."
                    >
                      <TextBlock
                        Classes="label"
                        Text="Y axis"
                        FontSize="12"
                        VerticalAlignment="Center"
                      />
                      <ComboBox
                        ItemsSource="{Binding ShownChannels}"
                        SelectedItem="{Binding AxisChannel}"
                        MinWidth="185"
                        FontSize="12"
                      >
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="vm:PlotChannelViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                              <Border
                                Width="10"
                                Height="10"
                                CornerRadius="3"
                                Background="{Binding Stroke}"
                                VerticalAlignment="Center"
                              />
                              <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                            </StackPanel>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>

                    <Button
                      Grid.Column="2"
                      Command="{Binding RemoveCommand}"
                      Padding="8,3"
                      FontSize="12"
                      VerticalAlignment="Center"
                      ToolTip.Tip="Remove this graph (the channels keep recording)"
                    >
                      ✕
                    </Button>
                  </Grid>
                  <controls:TimeSeriesPlot
                    Height="{Binding PlotHeight}"
                    Series="{Binding ShownChannels}"
                    AxisSeries="{Binding AxisChannel}"
                    AnchorTime="{Binding AxisChannel.AnchorTime, FallbackValue=0}"
                    GridBrush="{StaticResource StrokeBrush}"
                    LabelBrush="{StaticResource TextMutedBrush}"
                  />
                  <Thumb
                    Classes="resize"
                    DragDelta="OnResizeGraph"
                    ToolTip.Tip="Drag to resize this graph"
                  />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock
          Classes="label"
          Text="No graphs — press Add graph to create one."
          HorizontalAlignment="Center"
          Margin="0,24,0,0"
          IsVisible="{Binding !Plots.Graphs.Count}"
        />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
