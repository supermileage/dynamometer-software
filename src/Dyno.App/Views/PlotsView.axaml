<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:Dyno.App.ViewModels"
  xmlns:controls="using:Dyno.App.Controls"
  x:Class="Dyno.App.Views.PlotsView"
  x:DataType="vm:MainWindowViewModel"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <!-- The dividers between grid cells. Invisible until hovered — the gap between cards is
         itself the affordance — then lit in accent like every other resize handle in the app. -->
    <Style Selector="GridSplitter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="GridSplitter:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    </Style>
  </UserControl.Styles>

  <UserControl.Resources>
    <!-- One graph card. Instantiated from code-behind (PlotsView.axaml.cs), which lays the cards
         out in an auto-sized grid — a near-square arrangement recomputed as graphs come and go —
         with GridSplitters between rows and columns. A template rather than markup here because
         the grid's shape (and the splitters between cells) can't be expressed by a static panel. -->
    <DataTemplate x:Key="GraphCardTemplate" x:DataType="vm:PlotGraphViewModel">
      <Border Classes="card" Padding="12,8,12,10">
        <DockPanel>
          <Grid
            DockPanel.Dock="Top"
            ColumnDefinitions="*,Auto,Auto,Auto"
            ColumnSpacing="8"
            Margin="0,0,0,6"
          >
            <!-- The legend: only the channels this graph draws. Editing which lives in the
                 Channels flyout, so a cell's header stays one row instead of eight chips. -->
            <ItemsControl
              Grid.Column="0"
              ItemsSource="{Binding ShownChannels}"
              VerticalAlignment="Center"
            >
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel ItemSpacing="5" LineSpacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PlotChannelViewModel">
                  <Border
                    Background="{StaticResource SurfaceRaisedBrush}"
                    CornerRadius="6"
                    Padding="6,2"
                    ToolTip.Tip="{Binding Title}"
                  >
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <Border
                        Width="9"
                        Height="9"
                        CornerRadius="3"
                        Background="{Binding Stroke}"
                        VerticalAlignment="Center"
                      />
                      <TextBlock Text="{Binding Name}" FontSize="11" VerticalAlignment="Center" />
                      <!-- A channel that is streaming nothing draws no line and no axis; say so,
                           or it is indistinguishable from one hidden off-range. -->
                      <TextBlock
                        Text="no data"
                        FontSize="10"
                        FontStyle="Italic"
                        Opacity="0.7"
                        VerticalAlignment="Center"
                        IsVisible="{Binding !HasData}"
                      />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <DropDownButton
              Grid.Column="1"
              Content="Channels"
              FontSize="12"
              Padding="8,3"
              VerticalAlignment="Center"
              ToolTip.Tip="Choose which channels this graph draws"
            >
              <DropDownButton.Flyout>
                <Flyout Placement="BottomEdgeAlignedRight">
                  <ItemsControl ItemsSource="{Binding Series}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="2" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:PlotGraphSeriesViewModel">
                        <CheckBox IsChecked="{Binding IsShown}" MinHeight="0" Padding="6,0,0,0">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border
                              Width="10"
                              Height="10"
                              CornerRadius="3"
                              Background="{Binding Channel.Stroke}"
                              VerticalAlignment="Center"
                            />
                            <TextBlock Text="{Binding Channel.Title}" VerticalAlignment="Center" />
                          </StackPanel>
                        </CheckBox>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Flyout>
              </DropDownButton.Flyout>
            </DropDownButton>

            <!-- Every series is drawn against its own range (Settings > Plots, or its
                 autoscale fit); the numbers on the left belong to this channel only. -->
            <ComboBox
              Grid.Column="2"
              ItemsSource="{Binding ShownChannels}"
              SelectedItem="{Binding AxisChannel}"
              MinWidth="150"
              FontSize="12"
              VerticalAlignment="Center"
              ToolTip.Tip="Which channel's scale labels the y-axis. Every line is normalized to its own configured range, so shapes compare even when units differ."
            >
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PlotChannelViewModel">
                  <StackPanel Orientation="Horizontal" Spacing="7">
                    <Border
                      Width="10"
                      Height="10"
                      CornerRadius="3"
                      Background="{Binding Stroke}"
                      VerticalAlignment="Center"
                    />
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <Button
              Grid.Column="3"
              Command="{Binding RemoveCommand}"
              Padding="8,3"
              FontSize="12"
              VerticalAlignment="Center"
              ToolTip.Tip="Remove this graph (the channels keep recording)"
            >
              ✕
            </Button>
          </Grid>
          <controls:TimeSeriesPlot
            Series="{Binding ShownChannels}"
            AxisSeries="{Binding AxisChannel}"
            AnchorTime="{Binding AxisChannel.AnchorTime, FallbackValue=0}"
            GridBrush="{StaticResource StrokeBrush}"
            LabelBrush="{StaticResource TextMutedBrush}"
          />
        </DockPanel>
      </Border>
    </DataTemplate>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="10">
    <Border Grid.Row="0" Classes="card" Padding="12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
          <TextBlock Classes="heading" Text="PLOTS" />
          <TextBlock
            Classes="label"
            FontSize="12"
            Text="Plots cover the whole run: the x axis starts at 0 and reads elapsed seconds from the device's own timestamps. Stopping a session freezes the trace where it is; the next one is appended after the real gap, and only Clear empties the graphs. Each line is drawn against its own range (Settings > Plots, or autoscale), and the y-axis numbers belong to the channel picked on the graph."
            TextWrapping="Wrap"
          />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button
            Content="Clear"
            Command="{Binding Plots.ClearCommand}"
            ToolTip.Tip="Discard everything recorded so far and start the next sample at 0. Stopping a session does not clear the plots — this is the only thing that does."
          />
          <Button Classes="accent" Content="Add graph" Command="{Binding Plots.AddGraphCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Filled by code-behind: graphs in a near-square grid (1, 2 stacked, 2x2, 3x2, 3x3 …)
         with splitters between rows and columns. -->
    <Grid Grid.Row="1" x:Name="GraphsHost" />
  </Grid>
</UserControl>
