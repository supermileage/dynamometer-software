<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:Dyno.App.ViewModels"
  x:Class="Dyno.App.Views.SysConfigView"
  x:DataType="vm:MainWindowViewModel"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <!-- The parameter / #define name, as it appears in the firmware source. -->
    <Style Selector="TextBlock.definename">
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="TextBlock.paramdesc">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBox.definevalue">
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="MinWidth" Value="150" />
      <Setter Property="HorizontalContentAlignment" Value="Right" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <!-- A value the firmware would reject: out of range or not a number. -->
    <Style Selector="TextBox.definevalue.invalid">
      <Setter Property="BorderBrush" Value="#E5484D" />
    </Style>
    <Style Selector="ToggleSwitch.definevalue">
      <Setter Property="OnContent" Value="{x:Null}" />
      <Setter Property="OffContent" Value="{x:Null}" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Margin" Value="0" />
    </Style>
    <!-- Badge naming where a section's settings live / how they apply. -->
    <Style Selector="Border.filebadge">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="Padding" Value="7,2" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.filebadge TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
    <!-- Section divider between the runtime and compile-time halves of the page. -->
    <Style Selector="TextBlock.sectiontitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="1.2" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="14">
    <!-- Toolbar: title + search -->
    <Border Grid.Row="0" Classes="card" Padding="12">
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
        <TextBlock
          Grid.Column="0"
          Classes="heading"
          Text="SYSTEM CONFIGURATION"
          VerticalAlignment="Center"
          Margin="4,0,10,0"
        />
        <TextBox
          Grid.Column="1"
          Text="{Binding SysConfig.SearchText}"
          Watermark="Search settings — name, category or description (e.g. PID, task enable)"
          CornerRadius="7"
        />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <!-- ===================== DEVICE RUNTIME ===================== -->
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="10" Margin="4,0">
          <TextBlock
            Grid.Column="0"
            Classes="sectiontitle"
            Text="DEVICE RUNTIME"
            VerticalAlignment="Center"
          />
          <Border Grid.Column="1" Classes="filebadge">
            <TextBlock Text="applied over USB · saved on this PC" />
          </Border>
          <TextBlock
            Grid.Column="3"
            Text="{Binding SysConfig.RuntimeDirtySummary}"
            IsVisible="{Binding SysConfig.RuntimeDirtyCount}"
            Foreground="{StaticResource AccentBrush}"
            FontSize="12"
            VerticalAlignment="Center"
          />
          <Button
            Grid.Column="4"
            Classes="accent"
            Content="Apply"
            Command="{Binding SysConfig.ApplyRuntimeCommand}"
            ToolTip.Tip="Send the edited values to the running device and save them on this computer. Saved values re-apply automatically every time a device connects."
          />
        </Grid>
        <TextBlock
          Text="{Binding SysConfig.RuntimeStatusText}"
          Classes="paramdesc"
          Margin="4,-6,4,0"
        />

        <!-- The one runtime setting with its own routed command: applied via the force-sensor
             task (an I2C write), unlike the store parameters below. -->
        <Border Classes="card" IsVisible="{Binding SysConfig.ShowRuntimeCard}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Classes="definename" Text="Force sensor sample rate" />
              <TextBlock
                Classes="paramdesc"
                Text="ADS1115 data rate, applied immediately on the running device. Requires a connection."
              />
            </StackPanel>
            <StackPanel
              Grid.Column="1"
              Orientation="Horizontal"
              Spacing="8"
              VerticalAlignment="Center"
            >
              <ComboBox
                ItemsSource="{Binding SampleRates}"
                SelectedItem="{Binding SelectedSampleRate}"
                MinWidth="140"
              />
              <Button Classes="accent" Content="Set" Command="{Binding SetSampleRateCommand}" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- One card per runtime category. -->
        <ItemsControl ItemsSource="{Binding SysConfig.FilteredRuntimeCategories}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="12" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:RuntimeCategoryViewModel">
              <Border Classes="card">
                <StackPanel Spacing="4">
                  <TextBlock Classes="heading" Text="{Binding Name}" Margin="0,0,0,6" />
                  <ItemsControl ItemsSource="{Binding Parameters}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:RuntimeParameterViewModel">
                        <Grid
                          ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          Margin="0,5"
                        >
                          <!-- Pending-change marker -->
                          <Ellipse
                            Grid.Column="0"
                            Width="7"
                            Height="7"
                            VerticalAlignment="Center"
                            Fill="{StaticResource AccentBrush}"
                            IsVisible="{Binding IsDirty}"
                            ToolTip.Tip="Changed — not yet applied"
                          />
                          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Classes="definename" Text="{Binding Name}" />
                              <Border Classes="filebadge" IsVisible="{Binding HasUnit}">
                                <TextBlock Text="{Binding Unit}" />
                              </Border>
                            </StackPanel>
                            <TextBlock
                              Classes="paramdesc"
                              Text="{Binding Description}"
                              MaxWidth="520"
                              HorizontalAlignment="Left"
                            />
                            <TextBlock
                              Classes="paramdesc"
                              Text="{Binding RangeText}"
                              FontSize="10.5"
                            />
                          </StackPanel>
                          <TextBox
                            Grid.Column="3"
                            Classes="definevalue"
                            Classes.invalid="{Binding IsInvalid}"
                            Text="{Binding Text}"
                            VerticalAlignment="Center"
                          />
                          <Button
                            Grid.Column="4"
                            Content="Reset"
                            FontSize="11"
                            Padding="9,4"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsOverride}"
                            Command="{Binding ResetCommand}"
                            ToolTip.Tip="Forget the saved override and return to the firmware default"
                          />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ===================== COMPILE-TIME ===================== -->
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="10" Margin="4,14,4,0">
          <TextBlock
            Grid.Column="0"
            Classes="sectiontitle"
            Text="COMPILE-TIME"
            VerticalAlignment="Center"
          />
          <Border Grid.Column="1" Classes="filebadge">
            <TextBlock Text="edits config.h / debug.h · rebuild + flash to apply" />
          </Border>
          <TextBlock
            Grid.Column="3"
            Text="{Binding SysConfig.DirtySummary}"
            IsVisible="{Binding SysConfig.DirtyCount}"
            Foreground="{StaticResource AccentBrush}"
            FontSize="12"
            VerticalAlignment="Center"
          />
          <Button
            Grid.Column="4"
            Content="Reload"
            Command="{Binding SysConfig.ReloadCommand}"
            ToolTip.Tip="Re-read config.h and debug.h from disk, discarding unsaved edits"
          />
          <Button
            Grid.Column="5"
            Classes="accent"
            Content="Save to headers"
            Command="{Binding SysConfig.SaveCommand}"
            ToolTip.Tip="Write the edited values back into config.h / debug.h. They take effect on the next firmware build + flash."
          />
        </Grid>
        <TextBlock Text="{Binding SysConfig.StatusText}" Classes="paramdesc" Margin="4,-6,4,0" />

        <!-- One card per section of config.h / debug.h (buffer sizes, task/peripheral gates). -->
        <ItemsControl ItemsSource="{Binding SysConfig.FilteredCategories}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="12" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ConfigCategoryViewModel">
              <Border Classes="card">
                <StackPanel Spacing="4">
                  <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <TextBlock Classes="heading" Text="{Binding Name}" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Classes="filebadge">
                      <TextBlock Text="{Binding FileLabel}" />
                    </Border>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding Parameters}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:ConfigParameterViewModel">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,5">
                          <!-- Unsaved-change marker -->
                          <Ellipse
                            Grid.Column="0"
                            Width="7"
                            Height="7"
                            VerticalAlignment="Center"
                            Fill="{StaticResource AccentBrush}"
                            IsVisible="{Binding IsDirty}"
                            ToolTip.Tip="Changed — not yet saved to the header"
                          />
                          <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Classes="definename" Text="{Binding Name}" />
                            <TextBlock
                              Classes="paramdesc"
                              Text="{Binding Description}"
                              IsVisible="{Binding HasDescription}"
                              MaxWidth="560"
                              HorizontalAlignment="Left"
                            />
                          </StackPanel>
                          <Panel Grid.Column="2" VerticalAlignment="Center">
                            <ToggleSwitch
                              Classes="definevalue"
                              IsChecked="{Binding IsOn}"
                              IsVisible="{Binding IsBool}"
                            />
                            <TextBox
                              Classes="definevalue"
                              Text="{Binding Text}"
                              IsVisible="{Binding IsText}"
                            />
                          </Panel>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock
          Text="No settings match your search."
          IsVisible="{Binding SysConfig.HasNoMatches}"
          Foreground="{StaticResource TextMutedBrush}"
          HorizontalAlignment="Center"
          Margin="0,24"
        />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
