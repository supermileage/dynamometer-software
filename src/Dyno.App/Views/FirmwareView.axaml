<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:Dyno.App.ViewModels"
  xmlns:fw="using:Dyno.Core.Firmware"
  x:Class="Dyno.App.Views.FirmwareView"
  x:DataType="vm:MainWindowViewModel"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="TextBlock.sectiontitle">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="1.2" />
    </Style>
    <Style Selector="TextBlock.paramdesc">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <!-- The step number that heads each half of the page: build, then flash. -->
    <Style Selector="Border.step">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="CornerRadius" Value="11" />
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.step TextBlock">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- One of the three flashing methods. -->
    <Style Selector="ListBox.methods">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.methods ListBoxItem">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
    <Style Selector="TextBox.compact">
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <!-- Warnings that are advice, not failures (BOOT0, unapplied edits). -->
    <Style Selector="Border.notice">
      <Setter Property="Background" Value="#2A2415" />
      <Setter Property="BorderBrush" Value="#6B5A22" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="10,7" />
    </Style>
    <Style Selector="Border.notice TextBlock">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="#E8C97A" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.console">
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="14">
    <!-- Toolbar -->
    <Border Grid.Row="0" Classes="card" Padding="12">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
        <TextBlock
          Grid.Column="0"
          Classes="heading"
          Text="FIRMWARE"
          VerticalAlignment="Center"
          Margin="4,0,10,0"
        />
        <TextBlock
          Grid.Column="2"
          Text="{Binding Firmware.BusyText}"
          IsVisible="{Binding Firmware.IsBusy}"
          Foreground="{StaticResource AccentBrush}"
          FontSize="12"
          VerticalAlignment="Center"
        />
        <Button
          Grid.Column="3"
          Content="Stop"
          Command="{Binding Firmware.CancelCommand}"
          IsVisible="{Binding Firmware.IsBusy}"
          ToolTip.Tip="Kill the running command and everything it started"
        />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <!-- No firmware tree in reach: say so once, instead of offering buttons that can't work. -->
        <Border Classes="card" IsVisible="{Binding Firmware.IsUnavailable}">
          <TextBlock Classes="paramdesc" Text="{Binding Firmware.UnavailableText}" />
        </Border>

        <StackPanel Spacing="12" IsVisible="{Binding Firmware.IsAvailable}">
          <!-- ===================== 1. BUILD ===================== -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0">
            <Border Classes="step">
              <TextBlock Text="1" />
            </Border>
            <TextBlock Classes="sectiontitle" Text="BUILD" VerticalAlignment="Center" />
          </StackPanel>

          <Border Classes="card">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                <TextBlock
                  Grid.Column="0"
                  Text="Configuration"
                  VerticalAlignment="Center"
                  FontSize="12.5"
                />
                <ComboBox
                  Grid.Column="1"
                  ItemsSource="{Binding Firmware.Builds}"
                  SelectedItem="{Binding Firmware.SelectedBuild}"
                  MinWidth="120"
                />
                <CheckBox
                  Grid.Column="2"
                  Content="Rebuild toolchain image"
                  IsChecked="{Binding Firmware.RebuildImage}"
                  Margin="6,0,0,0"
                  ToolTip.Tip="Only needed after editing the Dockerfile. It turns a short build into a several-minute one."
                />
                <Button
                  Grid.Column="3"
                  Classes="accent"
                  Content="Build"
                  Command="{Binding Firmware.BuildCommand}"
                  ToolTip.Tip="Write the saved compile-time settings into the generated override headers, then build."
                />
              </Grid>

              <TextBlock Classes="paramdesc" Text="{Binding Firmware.BuildStatusText}" />

              <!-- What this build will actually bake in — the link back to the Config page. -->
              <StackPanel Spacing="4">
                <TextBlock Classes="paramdesc" Text="{Binding Firmware.OverridesSummary}" />
                <ItemsControl
                  ItemsSource="{Binding Firmware.Overrides}"
                  IsVisible="{Binding Firmware.HasOverrides}"
                >
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <TextBlock
                        Classes="console"
                        Text="{Binding}"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Margin="10,1,0,1"
                      />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <Border Classes="notice" IsVisible="{Binding Firmware.HasUnappliedEdits}">
                <TextBlock Text="{Binding Firmware.UnappliedEditsText}" />
              </Border>
            </StackPanel>
          </Border>

          <!-- ===================== 2. FLASH ===================== -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,8,4,0">
            <Border Classes="step">
              <TextBlock Text="2" />
            </Border>
            <TextBlock Classes="sectiontitle" Text="FLASH" VerticalAlignment="Center" />
          </StackPanel>

          <Border Classes="card">
            <Grid ColumnDefinitions="*,Auto,280" ColumnSpacing="16">
              <!-- How it connects -->
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Connection" FontSize="12.5" Margin="0,0,0,2" />
                <ListBox
                  Classes="methods"
                  ItemsSource="{Binding Firmware.Methods}"
                  SelectedItem="{Binding Firmware.SelectedMethod}"
                >
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:FlashMethodChoice">
                      <StackPanel Spacing="2">
                        <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" />
                        <TextBlock
                          Classes="paramdesc"
                          Text="{Binding Subtitle}"
                          MaxWidth="380"
                          HorizontalAlignment="Left"
                        />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>

              <Border
                Grid.Column="1"
                Width="1"
                Background="{StaticResource StrokeBrush}"
                Margin="0,4"
              />

              <!-- Which tool, and which board -->
              <StackPanel Grid.Column="2" Spacing="8">
                <TextBlock Text="Tool" FontSize="12.5" />
                <ComboBox
                  ItemsSource="{Binding Firmware.Tools}"
                  SelectedItem="{Binding Firmware.SelectedTool}"
                  HorizontalAlignment="Stretch"
                />
                <TextBlock Classes="paramdesc" Text="{Binding Firmware.ToolHint}" />

                <!-- Pick the board by clicking, not by copying a serial number out of a log. -->
                <Button
                  Content="Scan for devices"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Command="{Binding Firmware.ScanCommand}"
                  ToolTip.Tip="List the probes / DFU devices / serial ports that are plugged in, so you can click the one to flash"
                />
                <TextBlock Classes="paramdesc" Text="{Binding Firmware.DeviceStatus}" />

                <ListBox
                  Classes="methods"
                  ItemsSource="{Binding Firmware.Devices}"
                  SelectedItem="{Binding Firmware.SelectedDevice}"
                  IsVisible="{Binding Firmware.Devices.Count}"
                  MaxHeight="160"
                >
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="fw:FlashTarget">
                      <StackPanel Spacing="1">
                        <TextBlock Text="{Binding Label}" FontSize="12.5" FontWeight="SemiBold" />
                        <TextBlock
                          Text="{Binding Detail}"
                          FontFamily="{StaticResource MonoFont}"
                          FontSize="11"
                          Foreground="{StaticResource TextMutedBrush}"
                        />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <!-- The picked value, also typeable for a device a scan can't see (behind a
                     permission wall, or only present once in the bootloader). -->
                <StackPanel Spacing="4" IsVisible="{Binding Firmware.ShowSerial}">
                  <TextBlock Classes="paramdesc" Text="Serial number (optional)" />
                  <TextBox
                    Classes="compact"
                    Text="{Binding Firmware.Serial}"
                    Watermark="click a device above, or type it"
                  />
                </StackPanel>

                <StackPanel Spacing="4" IsVisible="{Binding Firmware.ShowIndex}">
                  <TextBlock Classes="paramdesc" Text="DFU index (port=USB&lt;n&gt;)" />
                  <TextBox Classes="compact" Text="{Binding Firmware.Index}" />
                </StackPanel>

                <StackPanel Spacing="4" IsVisible="{Binding Firmware.ShowPort}">
                  <TextBlock Classes="paramdesc" Text="Serial port" />
                  <TextBox Classes="compact" Text="{Binding Firmware.Port}" />
                  <TextBlock Classes="paramdesc" Text="Baud" />
                  <TextBox Classes="compact" Text="{Binding Firmware.Baud}" />
                </StackPanel>

                <Button
                  Classes="accent"
                  Content="Flash"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Margin="0,4,0,0"
                  Command="{Binding Firmware.FlashCommand}"
                  ToolTip.Tip="Program the built image to the board. Does not rebuild — press Build first if you changed anything."
                />
              </StackPanel>
            </Grid>
          </Border>

          <Border Classes="notice" IsVisible="{Binding Firmware.NeedsBootloader}">
            <TextBlock Text="This method uses the chip's built-in bootloader, which the board does not enter on its own: hold BOOT0 high and reset it before flashing. An SWD probe needs none of this." />
          </Border>

          <TextBlock
            Classes="paramdesc"
            IsVisible="{Binding Firmware.ShowLinuxPermissionsNote}"
            Text="On Linux, USB access is root-only until you install firmware/Scripts/99-stm32-flash.rules (probes and DFU) and join the dialout group (UART). Without that, flashing fails with a permission error."
            Margin="4,0"
          />

          <!-- Output moved to the window's log panel (its Console tab), which opens itself the
               moment a build, flash or scan runs — so it is visible from whatever page you are on,
               not only this one. -->
          <TextBlock
            Classes="paramdesc"
            Text="Build, flash and scan output appears in the Console tab of the log panel, which opens automatically when you start one."
            Margin="4,6,4,0"
          />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
