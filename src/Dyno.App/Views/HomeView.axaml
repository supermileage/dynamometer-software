<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:Dyno.App.ViewModels"
  xmlns:conv="using:Dyno.App.Converters"
  x:Class="Dyno.App.Views.HomeView"
  x:DataType="vm:MainWindowViewModel"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="14">
    <!-- Connection toolbar -->
    <Border Grid.Row="0" Classes="card" Padding="12">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <ComboBox
            ItemsSource="{Binding Ports}"
            SelectedItem="{Binding SelectedPort}"
            MinWidth="220"
            PlaceholderText="Select serial port"
          />
          <Button Content="Refresh" Command="{Binding RefreshPortsCommand}" />
          <Button Classes="accent" Content="Connect" Command="{Binding ConnectCommand}" />
          <Button Content="Disconnect" Command="{Binding DisconnectCommand}" />

          <!-- Status pill -->
          <Border
            CornerRadius="20"
            Background="{StaticResource SurfaceRaisedBrush}"
            Padding="12,5"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
          >
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Ellipse
                Width="9"
                Height="9"
                VerticalAlignment="Center"
                Fill="{Binding IsConnected, Converter={x:Static conv:BoolToStatusBrushConverter.Instance}}"
              />
              <TextBlock
                Text="{Binding ConnectionStatus}"
                VerticalAlignment="Center"
                FontSize="12"
              />
            </StackPanel>
          </Border>
        </StackPanel>

        <!--
          Session pill. The dyno streams sensor data only while a session runs, so an idle board
          and a dead one look identical on the wire; this is what tells them apart at a glance.
        -->
        <Border
          Grid.Column="2"
          CornerRadius="20"
          Background="{StaticResource SurfaceRaisedBrush}"
          Padding="12,5"
          Margin="8,0,0,0"
          VerticalAlignment="Center"
          ToolTip.Tip="Sensor data streams only while the dyno is running a session"
        >
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Ellipse
              Width="9"
              Height="9"
              VerticalAlignment="Center"
              Fill="{Binding IsSessionActive, Converter={x:Static conv:BoolToStatusBrushConverter.Instance}}"
            />
            <TextBlock
              Text="{Binding SessionStatus}"
              VerticalAlignment="Center"
              FontSize="12"
              FontWeight="SemiBold"
            />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- Telemetry + tasks -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="14">
      <Border Grid.Column="0" Classes="card">
        <StackPanel Spacing="0">
          <TextBlock Classes="heading" Text="TELEMETRY" Margin="0,0,0,12" />

          <!--
            Outside a session the device sends no sensor data, so there is nothing current to
            show: the readouts are replaced (not just frozen) by a notice saying why they're
            empty. A stale-but-plausible number left on screen reads as a live measurement.
          -->
          <Panel MinHeight="150">
            <StackPanel
              IsVisible="{Binding !IsSessionActive}"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Spacing="6"
            >
              <TextBlock
                Text="No session running"
                HorizontalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextMutedBrush}"
              />
              <TextBlock
                Text="Start a session on the dyno to stream sensor data."
                HorizontalAlignment="Center"
                TextWrapping="Wrap"
                TextAlignment="Center"
                FontSize="12"
                Foreground="{StaticResource TextMutedBrush}"
              />
            </StackPanel>

            <Grid
              IsVisible="{Binding IsSessionActive}"
              ColumnDefinitions="Auto,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="9"
              VerticalAlignment="Top"
            >
              <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Angular velocity" />
              <TextBlock
                Grid.Row="0"
                Grid.Column="1"
                Classes="readout"
                HorizontalAlignment="Right"
                Text="{Binding AngularVelocity, StringFormat='{}{0:F3} rad/s'}"
              />

              <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Angular acceleration" />
              <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Classes="readout"
                HorizontalAlignment="Right"
                Text="{Binding AngularAcceleration, StringFormat='{}{0:F3} rad/s²'}"
              />

              <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Force" />
              <TextBlock
                Grid.Row="2"
                Grid.Column="1"
                Classes="readout"
                HorizontalAlignment="Right"
                Text="{Binding Force, StringFormat='{}{0:F3} N'}"
              />

              <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="BPM duty cycle" />
              <TextBlock
                Grid.Row="3"
                Grid.Column="1"
                Classes="readout"
                HorizontalAlignment="Right"
                Text="{Binding DutyCycle, StringFormat='{}{0:P1}'}"
              />

              <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Last timestamp" />
              <TextBlock
                Grid.Row="4"
                Grid.Column="1"
                Classes="readout"
                HorizontalAlignment="Right"
                Text="{Binding LastTimestamp}"
              />
            </Grid>
          </Panel>

          <Border Height="1" Background="{StaticResource StrokeBrush}" Margin="0,14" />

          <!-- Which force sensor is feeding the reading above: sensor data, so session-gated too. -->
          <StackPanel
            Orientation="Horizontal"
            Margin="0,0,0,8"
            IsVisible="{Binding IsSessionActive}"
          >
            <TextBlock Classes="label" Text="Force source" VerticalAlignment="Center" />
            <TextBlock
              Classes="readout"
              Text="{Binding ForceSource}"
              Margin="8,0,0,0"
              VerticalAlignment="Center"
            />
          </StackPanel>

          <!-- Sample rate and other device settings live on the SysConfig page. -->
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Classes="card">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Classes="heading" Text="TASKS" Margin="0,0,0,10" />
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,6">
            <TextBlock Classes="label" FontSize="11" Text="task" />
            <TextBlock Grid.Column="1" Classes="label" FontSize="11" Text="state" Margin="12,0" />
            <TextBlock Grid.Column="2" Classes="label" FontSize="11" Text="free" />
          </Grid>
          <ItemsControl ItemsSource="{Binding Tasks}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:TaskMonitorRow">
                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,3">
                  <TextBlock Text="{Binding Task}" />
                  <TextBlock
                    Grid.Column="1"
                    Classes="readout"
                    FontSize="12"
                    Text="{Binding StateLabel}"
                    Margin="12,0"
                    MinWidth="72"
                    TextAlignment="Right"
                    ToolTip.Tip="{Binding State, StringFormat='raw osThreadState_t: {0}'}"
                  />
                  <TextBlock
                    Grid.Column="2"
                    Classes="readout"
                    FontSize="12"
                    Text="{Binding FreeBytes}"
                  />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Errors / events -->
    <Border Grid.Row="2" Classes="card" Height="200" Padding="12">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
          <TextBlock Classes="heading" Text="ERRORS / EVENTS" VerticalAlignment="Center" />
          <Button
            x:Name="CopyEventsButton"
            Grid.Column="1"
            Content="Copy"
            Padding="12,4"
            Margin="0,0,6,0"
            FontSize="12"
            Click="OnCopyEvents"
            ToolTip.Tip="Copy the selected lines — or all of them, if none are selected (Ctrl+C)"
          />
          <Button
            Grid.Column="2"
            Content="Clear"
            Padding="12,4"
            FontSize="12"
            Command="{Binding ClearEventsCommand}"
            ToolTip.Tip="Empty the list, e.g. before reproducing a problem"
          />
        </Grid>
        <ListBox
          x:Name="EventList"
          ItemsSource="{Binding Events}"
          SelectionMode="Multiple"
          KeyDown="OnEventListKeyDown"
        >
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock
                Text="{Binding}"
                FontFamily="{StaticResource MonoFont}"
                FontSize="12"
                Foreground="{Binding Converter={x:Static conv:EventLevelToBrushConverter.Instance}}"
              />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
