<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:vm="using:Dyno.App.ViewModels"
  xmlns:views="using:Dyno.App.Views"
  x:Class="Dyno.App.Views.MainWindow"
  x:DataType="vm:MainWindowViewModel"
  Title="Dyno"
  Width="1020"
  Height="680"
  MinWidth="780"
  MinHeight="660"
  Background="{StaticResource AppBackgroundBrush}"
  ExtendClientAreaToDecorationsHint="True"
  ExtendClientAreaChromeHints="NoChrome"
  ExtendClientAreaTitleBarHeightHint="-1"
>
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Styles>
    <!-- Window control buttons (minimize / maximize / close) -->
    <Style Selector="Button.chrome">
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.chrome Path">
      <Setter Property="Stroke" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="StrokeThickness" Value="1.1" />
    </Style>
    <Style Selector="Button.chrome:pointerover Path">
      <Setter Property="Stroke" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.chrome:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1AFFFFFF" />
    </Style>
    <Style Selector="Button.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#E81123" />
    </Style>
    <Style Selector="Button.close:pointerover Path">
      <Setter Property="Stroke" Value="White" />
    </Style>

    <!-- Sidebar navigation buttons: icon over a tiny caption; .active marks the current page. -->
    <Style Selector="Button.nav">
      <Setter Property="Width" Value="52" />
      <Setter Property="Height" Value="52" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.nav Path">
      <Setter Property="Stroke" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="StrokeThickness" Value="1.6" />
      <Setter Property="Fill" Value="Transparent" />
      <Setter Property="StrokeJoin" Value="Round" />
      <Setter Property="StrokeLineCap" Value="Round" />
    </Style>
    <Style Selector="Button.nav TextBlock">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.nav:pointerover Path">
      <Setter Property="Stroke" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.nav:pointerover TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1AFFFFFF" />
    </Style>
    <Style Selector="Button.nav.active">
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
    </Style>
    <!-- Badge on the collapsed event log: how much arrived while it was shut. Grey for routine
         traffic, red once any of it was an error or a warning — "22 new" and "22 new, one of them
         a fault" are not the same news. -->
    <Style Selector="Border.missed">
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="7,2" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Background" Value="{StaticResource SurfaceRaisedBrush}" />
    </Style>
    <Style Selector="Border.missed TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>
    <Style Selector="Border.missed.problem">
      <Setter Property="Background" Value="#E5484D" />
    </Style>
    <Style Selector="Border.missed.problem TextBlock">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.nav.active Path">
      <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="Button.nav.active TextBlock">
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>
  </Window.Styles>

  <!--
    When the window maximizes with an extended client area, the OS sizes it a little larger than
    the screen on every edge (with native chrome that overhang is the invisible resize border).
    Our borderless chrome has nothing to spare there, so the title bar, window buttons, and bottom
    panel would be clipped off-screen. OffScreenMargin reports exactly that overhang — zero when
    not maximized — so binding it here insets the whole UI back onto the screen.
  -->
  <Panel Margin="{Binding $parent[Window].OffScreenMargin}">
    <Grid RowDefinitions="Auto,*">
      <!-- Custom title bar -->
      <Border
        x:Name="TitleBar"
        Grid.Row="0"
        Height="40"
        Background="{StaticResource SurfaceColor}"
        BorderBrush="{StaticResource StrokeBrush}"
        BorderThickness="0,0,0,1"
        PointerPressed="OnTitleBarPointerPressed"
        DoubleTapped="OnTitleBarDoubleTapped"
      >
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel
            Grid.Column="0"
            Orientation="Horizontal"
            Spacing="10"
            Margin="14,0,0,0"
            VerticalAlignment="Center"
          >
            <Border Width="22" Height="22" CornerRadius="6">
              <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                  <GradientStop Color="#4C8DFF" Offset="0" />
                  <GradientStop Color="#6366F1" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock
                Text="D"
                Foreground="White"
                FontSize="13"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
              />
            </Border>
            <TextBlock Text="Dyno" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock
              Text="dynamometer console"
              FontSize="12"
              Foreground="{StaticResource TextMutedBrush}"
              VerticalAlignment="Center"
            />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
            <Button Classes="chrome" Click="OnMinimize" ToolTip.Tip="Minimize">
              <Path Data="M0,5 L11,5" />
            </Button>
            <Button Classes="chrome" Click="OnMaximizeRestore" ToolTip.Tip="Maximize">
              <Path x:Name="MaximizeIcon" Data="M0,0 L10,0 L10,10 L0,10 Z" Fill="Transparent" />
            </Button>
            <Button Classes="chrome close" Click="OnClose" ToolTip.Tip="Close">
              <Path Data="M0,0 L11,11 M0,11 L11,0" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Sidebar + active page -->
      <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
        <Border
          Grid.Column="0"
          Width="64"
          Background="{StaticResource SurfaceColor}"
          BorderBrush="{StaticResource StrokeBrush}"
          BorderThickness="0,0,1,0"
        >
          <StackPanel Spacing="6" Margin="0,12,0,0" HorizontalAlignment="Center">
            <Button
              Classes="nav"
              Classes.active="{Binding IsHomePage}"
              Command="{Binding NavigateCommand}"
              CommandParameter="{x:Static vm:AppPage.Home}"
              ToolTip.Tip="Home — live telemetry and events"
            >
              <StackPanel Spacing="3">
                <!-- House -->
                <Path
                  Width="24"
                  Height="24"
                  Data="M4,11 L12,4 L20,11 M6,9.5 L6,20 L18,20 L18,9.5 M10,20 L10,14.5 L14,14.5 L14,20"
                />
                <TextBlock Text="Home" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding IsSysConfigPage}"
              Command="{Binding NavigateCommand}"
              CommandParameter="{x:Static vm:AppPage.SysConfig}"
              ToolTip.Tip="SysConfig — firmware and device settings"
            >
              <StackPanel Spacing="3">
                <!-- Adjustment sliders -->
                <Path
                  Width="24"
                  Height="24"
                  Data="M4,7 L7.8,7 M12.2,7 L20,7 M10,4.8 A2.2,2.2 0 1 0 10,9.2 A2.2,2.2 0 1 0 10,4.8 M4,12 L12.8,12 M17.2,12 L20,12 M15,9.8 A2.2,2.2 0 1 0 15,14.2 A2.2,2.2 0 1 0 15,9.8 M4,17 L5.8,17 M10.2,17 L20,17 M8,14.8 A2.2,2.2 0 1 0 8,19.2 A2.2,2.2 0 1 0 8,14.8"
                />
                <TextBlock Text="Config" />
              </StackPanel>
            </Button>
            <Button
              Classes="nav"
              Classes.active="{Binding IsFirmwarePage}"
              Command="{Binding NavigateCommand}"
              CommandParameter="{x:Static vm:AppPage.Firmware}"
              ToolTip.Tip="Firmware — build and flash the board"
            >
              <StackPanel Spacing="3">
                <!-- Microchip -->
                <Path
                  Width="24"
                  Height="24"
                  Data="M7,7 L17,7 L17,17 L7,17 Z M10,10 L14,10 L14,14 L10,14 Z M9.5,7 L9.5,4 M14.5,7 L14.5,4 M9.5,17 L9.5,20 M14.5,17 L14.5,20 M7,9.5 L4,9.5 M7,14.5 L4,14.5 M17,9.5 L20,9.5 M17,14.5 L20,14.5"
                />
                <TextBlock Text="Firmware" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!--
          The page, with the event log beneath it. The log belongs to the window, not to a page:
          the events worth seeing (a rejected write, a lost link) happen while you are on the page
          that caused them. Pinned, it takes the bottom row and the page ends above it; unpinned, it
          floats over the page instead of shortening it; hidden, it is a one-line bar that still
          says what you missed.
        -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto">
          <!-- Every page stays alive so Home keeps accumulating events while another is open. -->
          <Panel Grid.Row="0">
            <views:HomeView IsVisible="{Binding IsHomePage}" />
            <views:SysConfigView IsVisible="{Binding IsSysConfigPage}" />
            <views:FirmwareView IsVisible="{Binding IsFirmwarePage}" />

            <Border
              VerticalAlignment="Bottom"
              Margin="16"
              CornerRadius="10"
              BoxShadow="0 10 30 0 #99000000"
              IsVisible="{Binding IsEventLogFloating}"
            >
              <views:EventLogView Height="{Binding EventLogHeight}" />
            </Border>
          </Panel>

          <views:EventLogView
            Grid.Row="1"
            Margin="16,0,16,16"
            Height="{Binding EventLogHeight}"
            IsVisible="{Binding IsEventLogDocked}"
          />

          <!-- Collapsed: still the newest line, and a count of what arrived while it was shut. -->
          <Border
            Grid.Row="1"
            Classes="card"
            Margin="16,0,16,16"
            Padding="12,7"
            IsVisible="{Binding IsEventLogCollapsed}"
          >
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
              <TextBlock
                Grid.Column="0"
                Classes="heading"
                Text="ERRORS / EVENTS"
                VerticalAlignment="Center"
              />
              <Border
                Grid.Column="1"
                Classes="missed"
                Classes.problem="{Binding MissedAProblem}"
                IsVisible="{Binding HasMissedEvents}"
              >
                <TextBlock Text="{Binding MissedEventsText}" />
              </Border>
              <TextBlock
                Grid.Column="2"
                Text="{Binding LatestEvent}"
                FontFamily="{StaticResource MonoFont}"
                FontSize="11.5"
                Foreground="{StaticResource TextMutedBrush}"
                TextTrimming="CharacterEllipsis"
                VerticalAlignment="Center"
              />
              <Button
                Grid.Column="3"
                Content="Show"
                Padding="10,4"
                FontSize="12"
                Command="{Binding ShowEventLogCommand}"
                ToolTip.Tip="Bring the log back"
              />
            </Grid>
          </Border>
        </Grid>
      </Grid>
    </Grid>

    <!--
    Resize grips for when SystemDecorations is None (Linux; see MainWindow.axaml.cs):
    without WM decorations there are no native resize borders, so these transparent
    strips call BeginResizeDrag. Hidden on platforms that keep the native frame,
    and while maximized.
  -->
    <Grid x:Name="ResizeGrips" IsVisible="False">
      <Rectangle
        Tag="West"
        Cursor="LeftSide"
        Fill="Transparent"
        HorizontalAlignment="Left"
        Width="5"
        Margin="0,12"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="East"
        Cursor="RightSide"
        Fill="Transparent"
        HorizontalAlignment="Right"
        Width="5"
        Margin="0,12"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="North"
        Cursor="TopSide"
        Fill="Transparent"
        VerticalAlignment="Top"
        Height="5"
        Margin="12,0"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="South"
        Cursor="BottomSide"
        Fill="Transparent"
        VerticalAlignment="Bottom"
        Height="5"
        Margin="12,0"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="NorthWest"
        Cursor="TopLeftCorner"
        Fill="Transparent"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Width="12"
        Height="12"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="NorthEast"
        Cursor="TopRightCorner"
        Fill="Transparent"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Width="12"
        Height="12"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="SouthWest"
        Cursor="BottomLeftCorner"
        Fill="Transparent"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Width="12"
        Height="12"
        PointerPressed="OnResizeGripPressed"
      />
      <Rectangle
        Tag="SouthEast"
        Cursor="BottomRightCorner"
        Fill="Transparent"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Width="12"
        Height="12"
        PointerPressed="OnResizeGripPressed"
      />
    </Grid>
  </Panel>
</Window>
